# === Harness tarafindan skorlanan kosuda enjekte edilenler ===
# (yerel testte kendi Fireworks hesabinin degerlerini kullan)
FIREWORKS_API_KEY=fw_...
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/minimax-m3,accounts/fireworks/models/kimi-k2p7-code,accounts/fireworks/models/gemma-4-31b-it,accounts/fireworks/models/gemma-4-26b-a4b-it,accounts/fireworks/models/gemma-4-31b-it-nvfp4

# === Opsiyonel: otomatik rol atamasini elle override etmek icin ===
# DEFAULT_MODEL=
# REASONING_MODEL=
# CODE_MODEL=

# === Opsiyonel ayarlar (varsayilanlar Track 1 kurallarina zaten uygun) ===
# ACCURACY_THRESHOLD=0.8
# REQUEST_TIMEOUT_SECONDS=25
# DEFAULT_MAX_TOKENS=1024
# TASKS_INPUT_PATH=/input/tasks.json
# RESULTS_OUTPUT_PATH=/output/results.json
# MAX_RUNTIME_SECONDS=600
# RUNTIME_SAFETY_MARGIN_SECONDS=20

# === Gemma 4 (bonus) - SADECE yerel test icin, bkz. HANDOFF.md ===
# GEMMA_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it
# GEMMA_DEPLOYMENT_ID=optiroute-gemma
# GEMMA_MIN_REPLICA_COUNT=0
# GEMMA_MAX_REPLICA_COUNT=1
# GEMMA_SCALE_TO_ZERO_WINDOW=10m
# GEMMA_ACCELERATOR_TYPE=
# GEMMA_QUERY_MODEL_ID=
